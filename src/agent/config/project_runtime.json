{
  "compaction": {
    // 默认压缩配置。当前模型厂商没有专属配置时，直接使用这里的参数。
    "default": {
      // 是否开启旧 tool result 的占位压缩。为 false 时，旧工具结果不会被替换成占位符。
      "tool_result_prune_enabled": true,
      // 按 role=tool 消息计数，保留最近多少条 tool result 不做占位压缩。
      "tool_result_keep_recent": 5,
      // 只有旧 tool result 的字符数大于这个阈值时，才会被替换成占位符。
      "tool_result_prune_min_chars": 100,
      // 触发摘要压缩的近似 token 阈值。上下文估算值超过它后，会生成 summary checkpoint。
      "summary_trigger_threshold": 170000,
      // 生成摘要压缩时，发给大模型的 max_tokens 上限。
      "summary_max_tokens": 12000,
      // 单次 tool 输出写回上下文前，允许保留的最大行数。
      "tool_output_max_lines": 2000,
      // 单次 tool 输出写回上下文前，允许保留的最大字节数。
      "tool_output_max_bytes": 51200
    },
    // 按模型厂商 vendor 做局部覆盖。只需要填写和 default 不同的字段，未填写字段会继承 default。
    "vendors": {}
  },
  "file_extraction": {
    // 文件抽取能力的默认配置。当前仅 Kimi 会消费该配置，后续可按 vendor 渐进扩展。
    "default": {
      // 允许走“上传文件 -> 抽取内容 -> 注入上下文”链路的文件扩展名。
      "allowed_extensions": [".pdf"],
      // 抽取完成后的远端清理策略。当前仅支持异步删除，且删除失败不影响主流程。
      "cleanup_mode": "async_delete"
    },
    // 按模型厂商 vendor 做局部覆盖。只需要填写和 default 不同的字段。
    "vendors": {
      "kimi": {}
    }
  },
  "agent_loop": {
    // 单次 agent loop 允许执行的最大轮次。命中上限后会以 error 收口，避免 unknown 持续空转。
    "max_rounds": 100
  },
  "subagent_loop": {
    // 单次 subagent loop 允许执行的最大轮次。subagent 通常需要更多轮次来完成复杂探索任务。
    "max_rounds": 50
  },
  "logging": {
    // 是否启用普通日志文本截断。关闭后会保留完整日志文本，但仍执行换行转义与敏感信息脱敏。
    "truncate_enabled": false,
    // 启用截断时，单个日志字段允许保留的最大字符数。
    "truncate_limit": 500
  },
  "session_memory": {
    // 是否按消息条数裁剪会话历史。关闭后会保留全部非 system 消息，但仍保留 checkpoint 相关收口逻辑。
    "trim_enabled": true,
    // 开启裁剪时，最多保留最近多少条非 system 消息。
    "max_messages": 50
  },
  "lsp": {
    // 是否启用文件写入/编辑后的 LSP 诊断链路。
    "enabled": true,
    // 是否允许后续接入 IDE LSP 代理模式。
    "ide_enabled": false,
    // 当前仅支持按需启动语言服务。
    "startup_mode": "on_demand",
    // 语言服务空闲多久后自动回收。
    "server_idle_ttl_seconds": 900,
    // 单次等待 diagnostics 的超时时间。
    "request_timeout_ms": 60000,
    // 返回给 Agent 的最大诊断条数。
    "max_diagnostics": 20,
    // 返回给 Agent 的最大诊断字符数。
    "max_chars": 4000,
    // 当前默认只回传 error 与 warning。
    "include_severity": ["error", "warning"],
    // 收到首个 diagnostics 后，继续等待多少毫秒以捕获同一文件后续 publishDiagnostics。
    "diagnostics_stable_window_ms": 800,
    // 等待稳定态时，最多额外接受多少轮新的 diagnostics 刷新。
    "diagnostics_max_wait_rounds": 4,
    // 是否输出 Java LSP 的原始 status/log/publish 观测明细，用于排查多模块 Maven 导入问题。
    "java_debug_observation_enabled": true,
    // LSP 不可用时是否提升为强告警。不会改变文件工具成功语义。
    "strict_unavailable": false,
    "languages": {
      "java": {
        "enabled": true,
        "command": [
          "/usr/bin/env",
          "JAVA_HOME=/Library/Java/JavaVirtualMachines/jdk-21.jdk/Contents/Home",
          "/opt/homebrew/bin/jdtls"
        ],
        // 多模块 Maven 项目可在这里显式指定导入 profile，避免默认 profile 冲突导致源码树未进入 Java Model。
        "maven_profiles": ["hna"],
        // 若 IDE 使用了非默认本地 Maven 仓库，需要在这里显式对齐，避免 jdtls 回落到 ~/.m2 后解析不到私有依赖。
        "maven_local_repository": "/Users/liurui/work_space/tools/apache-maven-3.9.3/repository",
        "file_extensions": [".java"],
        "workspace_markers": ["pom.xml", "build.gradle", "settings.gradle"],
        "init_options": {}
      },
      "python": {
        "enabled": true,
        "command": ["pylsp"],
        "file_extensions": [".py"],
        "workspace_markers": ["pyproject.toml", "setup.py", "requirements.txt", "setup.cfg"],
        "init_options": {}
      },
      "typescript": {
        "enabled": false,
        "command": [],
        "file_extensions": [".ts", ".tsx", ".js", ".jsx"],
        "workspace_markers": ["package.json", "tsconfig.json"],
        "init_options": {}
      }
    },
    "ide": {
      "transport": "",
      "endpoint": ""
    }
  }
}
